import pandas as pd
from io import StringIO


def load_historical_from_s3(s3_client, bucket, key):
    response = s3_client.get_object(Bucket=bucket, Key=key)
    csv_content = response['Body'].read().decode('utf-8')
    df = pd.read_csv(StringIO(csv_content))
    return df


def extrapolate_and_compare(
    current_df,
    historical_df,
    date_column="timestamp",
    value_column="monthly_engagement_score",
    key_columns=None,
    window=3
):

    if key_columns is None:
        raise ValueError("key_columns must be provided")

    historical_df[date_column] = pd.to_datetime(historical_df[date_column])
    current_df[date_column] = pd.to_datetime(current_df[date_column])

    current_month = current_df[date_column].max()

    historical_filtered = historical_df[
        historical_df[date_column] < current_month
    ].sort_values(date_column)

    last_n_months = (
        historical_filtered
        .groupby(key_columns)
        .tail(window)
    )

    extrapolated_df = (
        last_n_months
        .groupby(key_columns)[value_column]
        .mean()
        .reset_index()
    )

    extrapolated_df[date_column] = current_month
    extrapolated_df["project"] = current_df["project"].unique()[0]

    total_extrapolated = extrapolated_df[value_column].sum()
    total_actual = current_df[value_column].sum()

    print("Total Extrapolated:", total_extrapolated)
    print("Total Actual:", total_actual)

    if total_extrapolated >= total_actual:
        print("Using Extrapolated Data")
        return extrapolated_df
    else:
        print("Using Actual Current Month Data")
        return current_df


