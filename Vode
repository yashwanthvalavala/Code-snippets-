# BRANCH
def search_dc_task_init_callable(ti, **context):
    config = context['params']
    category = config['category'][0]

    if category.lower() in [x.lower() for x in SPECIAL_CATEGORIES]:
        return 'dc_search_overlap_task'
    else:
        return 'dc_search_task'


# SEARCH TASK
def search_dc_task_callable(ti, **context):
    task_id = context['task'].task_id
    dag_run_id = context['dag_run'].run_id
    config = copy.deepcopy(context['params'])

    default_start_date = '2014-01-01'
    timeframe = config['timeframe']
    end_date = timeframe[0].split(' ')[1]

    config.update({
        "threads": 5,
        "timeframe": [f"{default_start_date} {end_date}"],
        "task_id": task_id,
        "dag_run_id": dag_run_id,
        "dag_id": current_dag_id
    })

    s = dc_search_google(config)

    # Run existing logic
    s.start_process()

    # NEW SAFE HELPER METHOD
    current_df = s.get_final_dataframe()

    if not current_df.empty:
        ti.xcom_push(key="current_df", value=current_df.to_json())


