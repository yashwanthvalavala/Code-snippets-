def search_dc_extrapolation_task_callable(ti, **context):

    config = context['params']
    folder_name = config['folder_name']
    country = config['country'][0]
    category = config['category'][0]
    lens = config['lens'][0]

    bucket = "aipalette-retail-products"
    key = f"{folder_name}/{country.replace(' ','_')}_{category.replace(' ','_')}_{lens}.csv"

    s3 = boto3.client("s3")

    # Historical data from S3
    historical_df = load_historical_from_s3(s3, bucket, key)
    historical_df['timestamp'] = pd.to_datetime(historical_df['timestamp'])

    # Current DF from XCom
    current_df_json = ti.xcom_pull(
        task_ids=['dc_search_task', 'dc_search_overlap_task'],
        key="current_df"
    )

    current_df_json = [x for x in current_df_json if x is not None][0]
    current_df = pd.read_json(current_df_json)
    current_df['timestamp'] = pd.to_datetime(current_df['timestamp'])

    # Extrapolation
    final_month_df = extrapolate_and_compare(
        current_df=current_df,
        historical_df=historical_df,
        date_column="timestamp",
        value_column="monthly_engagement_score",
        key_columns=[lens]
    )

    current_month = final_month_df['timestamp'].max()

    historical_df = historical_df[
        historical_df['timestamp'] != current_month
    ]

    final_df = pd.concat([historical_df, final_month_df], ignore_index=True)

    csv_buffer = StringIO()
    final_df.to_csv(csv_buffer, index=False)

    s3.put_object(Bucket=bucket, Key=key, Body=csv_buffer.getvalue())


